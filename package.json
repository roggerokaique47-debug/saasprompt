{
  "name": "prompthub",
  "version": "0.1.0",
  "private": true,
  "description": "PromptHub — Sua biblioteca inteligente de prompts de IA",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:ci": "turbo test:ci",
    "test:e2e": "turbo test:e2e",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @prompthub/database db:generate",
    "db:push": "pnpm --filter @prompthub/database db:push",
    "db:migrate": "pnpm --filter @prompthub/database db:migrate",
    "db:seed": "pnpm --filter @prompthub/database db:seed",
    "db:studio": "pnpm --filter @prompthub/database db:studio"
  },
  "devDependencies": {
    "prettier": "^3.9.4",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "^0.45.2",
      "google-auth-library": "^9.0.0"
    }
  }
}
